# Copy to ".env" and fill in. The real .env and the auth/ folder are git-ignored.

# --- Shopify --------------------------------------------------------------
SHOPIFY_STORE=ppvzn0-w1.myshopify.com
SHOPIFY_API_VERSION=2026-01
INCLUDE_LOW_STOCK=true
LOW_STOCK_THRESHOLD=2

# Auth: create an app in the Shopify Dev Dashboard (dev.shopify.com), add the
# read_products scope, install it on your store, then copy Client ID + Secret
# from the app's Settings page. The bot mints a fresh 24h token itself.
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
# (Alternatively, if you already have a direct token, set this instead:)
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- WhatsApp -------------------------------------------------------------
# The DEDICATED number that sends (digits only, country code, no +, no spaces).
# It must already be registered in the WhatsApp app on the spare phone.
SENDER_NUMBER=9715XXXXXXXX

# Who receives the alert. Comma-separated. Any format (+, spaces ok).
RECIPIENTS=+971543043764

# Schedule (cron, UTC). Default = every 3 days at 06:00 UTC (10:00 Gulf).
CRON=0 6 */3 * *

# Set to "debug" to see verbose Baileys logs while troubleshooting.
WA_LOG_LEVEL=silent
